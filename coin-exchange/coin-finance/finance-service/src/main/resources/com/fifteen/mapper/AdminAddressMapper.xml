        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.fifteen.mapper.AdminAddressMapper">

    <resultMap id="BaseResultMap" type="com.fifteen.domain.AdminAddress">
            <id property="id" column="id" />
